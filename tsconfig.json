{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "outDir": "build",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "vscode": ["../../node_modules/@types/vscode"]
    },
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": ["src/modules/webview"]
}
