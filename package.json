{
  "name": "diplodoc-vsc-extension",
  "displayName": "Diplodoc Extension",
  "publisher": "diplodoc",
  "icon": "assets/diplodoc-logo.png",
  "description": "Diplodoc Extension for VSC",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diplodoc-platform/vsc"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "type": "commonjs",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:yaml"
  ],
  "main": "./build/index.js",
  "contributes": {
    "keybindings": [
      {
        "command": "diplodoc.insertTable",
        "key": "alt+t",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertNote",
        "key": "alt+r",
        "when": "editorLangId == markdown && editorTextFocus"
      }
    ],
    "commands": [
      {
        "command": "diplodoc.openMdEditor",
        "title": "Open Diplodoc Markdown Editor",
        "icon": "assets/diplodoc-logo-colored.svg"
      },
      {
        "command": "diplodoc.openTocEditor",
        "title": "Open Diplodoc TOC Editor",
        "icon": "assets/diplodoc-logo-colored.svg"
      },
      {
        "command": "diplodoc.insertTable",
        "title": "Diplodoc: Insert Table"
      },
      {
        "command": "diplodoc.insertNote",
        "title": "Diplodoc: Insert Note"
      }
    ],
    "languages": [
      {
        "id": "yaml",
        "filenames": [
          ".yfm",
          ".yfmlint"
        ],
        "extensions": [
          ".yfm",
          ".yfmlint"
        ]
      }
    ],
    "yamlValidation": [
      {
        "fileMatch": "**/toc.yaml",
        "url": "./schemas/toc-schema.json"
      },
      {
        "fileMatch": "**/.yfm",
        "url": "./schemas/yfm-schema.json"
      },
      {
        "fileMatch": "**/.yfm.yaml",
        "url": "./schemas/yfm-schema.json"
      },
      {
        "fileMatch": "**/presets.yaml",
        "url": "./schemas/presets-schema.json"
      },
      {
        "fileMatch": "**/redirects.yaml",
        "url": "./schemas/redirects-schema.json"
      },
      {
        "fileMatch": "**/.yfmlint",
        "url": "./schemas/yfmlint-schema.json"
      },
      {
        "fileMatch": "**/index.yaml",
        "url": "./schemas/leading-schema.json"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "diplodoc.openMdEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@1"
        },
        {
          "command": "diplodoc.openTocEditor",
          "when": "resourceFilename == toc.yaml",
          "group": "navigation@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "diplodoc-extension",
          "title": "Diplodoc",
          "icon": "./assets/diplodoc-logo-colored.svg"
        }
      ]
    },
    "views": {
      "diplodoc-extension": [
        {
          "type": "webview",
          "id": "diplodoc-extension-view",
          "name": "Diplodoc",
          "icon": "./assets/diplodoc-logo-colored.svg"
        }
      ]
    }
  },
  "scripts": {
    "compile:ext": "BUILD_TARGET=ext node esbuild.js",
    "compile:webview": "BUILD_TARGET=webview node esbuild.js",
    "compile": "node esbuild.js",
    "watch:ext": "BUILD_TARGET=ext node esbuild.js --watch",
    "watch:webview": "BUILD_TARGET=webview node esbuild.js --watch",
    "typecheck": "tsc -p . --noEmit",
    "vsce": "vsce package --no-dependencies",
    "merge-schemas": "node scripts/merge-schemas.js"
  },
  "dependencies": {
    "@diplodoc/latex-extension": "^1.4.1",
    "@diplodoc/mermaid-extension": "^2.0.0",
    "@diplodoc/transform": "^4.73.2",
    "@diplodoc/yfmlint": "^1.6.0",
    "@gravity-ui/components": "^4.18.0",
    "@gravity-ui/markdown-editor": "^15.37.0",
    "@gravity-ui/uikit": "^7.36.1",
    "ajv": "^8.18.0",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "markdown-it": "^13.0.2",
    "punycode": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "esbuild-sass-plugin": "^3.7.0",
    "sass": "^1.98.0",
    "typescript": "^6.0.2"
  }
}