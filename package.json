{
  "name": "vsc",
  "displayName": "Diplodoc Extension",
  "publisher": "Diplodoc",
  "icon": "assets/diplodoc-logo.png",
  "description": "Diplodoc Extension for VSC",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diplodoc-platform/vsc"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "type": "commonjs",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./build/index.js",
  "contributes": {
    "commands": [
      {
        "command": "diplodoc.openEditor",
        "title": "Open Diplodoc Editor",
        "icon": "assets/diplodoc-logo-colored.svg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "diplodoc.openEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "diplodoc-extension",
          "title": "Diplodoc Markdown Editor",
          "icon": "./assets/diplodoc-logo-colored.svg"
        }
      ]
    },
    "views": {
      "diplodoc-extension": [
        {
          "type": "webview",
          "id": "diplodoc-extension-view",
          "name": "Diplodoc Markdown Editor",
          "icon": "./assets/diplodoc-logo-colored.svg"
        }
      ]
    }
  },
  "scripts": {
    "compile:ext": "tsc -p .",
    "compile:webview": "node esbuild.js",
    "compile": "npm run compile:ext && npm run compile:webview",
    "watch:ext": "tsc -watch -p .",
    "watch:webview": "node esbuild.js --watch",
    "vsce": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@diplodoc/transform": "^4.72.0",
    "@gravity-ui/components": "^4.18.0",
    "@gravity-ui/markdown-editor": "^15.37.0",
    "@gravity-ui/uikit": "^7.35.2",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "markdown-it": "^13.0.2",
    "punycode": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  }
}
