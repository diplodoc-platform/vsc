{
  "name": "diplodoc-vsc-extension",
  "displayName": "Diplodoc Extension",
  "publisher": "diplodoc",
  "icon": "assets/diplodoc-logo.png",
  "description": "Diplodoc Extension for VSC",
  "version": "1.0.0",
  "license": "MIT",
  "telemetryKey": "YOUR-APPLICATION-INSIGHTS-CONNECTION-STRING",
  "repository": {
    "type": "git",
    "url": "https://github.com/diplodoc-platform/vsc"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "type": "commonjs",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:yaml"
  ],
  "main": "./build/index.js",
  "contributes": {
    "configuration": {
      "title": "Diplodoc",
      "properties": {
        "diplodoc.editorMode": {
          "type": "string",
          "enum": [
            "wysiwyg",
            "markup"
          ],
          "default": "wysiwyg",
          "description": "Default mode for Markdown editor."
        },
        "diplodoc.isOnlyYfm": {
          "type": "boolean",
          "default": false,
          "description": "Should only MD files within a YFM project be validated? Valid page-constructor blocks are validated regardless of this option."
        },
        "diplodoc.excludedDirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Additional directories to exclude from validation and file scanning. Each entry is matched against path segments by exact name or as a regular expression (e.g. `^docs-gen.*`). Useful when build output directory is specified via CLI flag (e.g. `yfm -o docs-gen`). The extension always excludes `node_modules`, `_build`, and the `output` directory from `.yfm` config."
        },
        "diplodoc.excludedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "^README(?:\\.[a-z]{2})?\\.md$",
            "^AGENTS(?:\\.[a-z]{2})?\\.md$",
            "^CONTRIBUTING(?:\\.[a-z]{2})?\\.md$",
            "^CHANGELOG(?:\\.[a-z]{2})?\\.md$"
          ],
          "markdownDescription": "Files located inside the yfm project, but which do not need to be validated."
        },
        "diplodoc.lintRules": {
          "type": "object",
          "default": {},
          "additionalProperties": true,
          "markdownDescription": "MD/YFM lint rules applied to all Markdown files. Same format as `.yfmlint` (e.g. `{ \"MD013\": false, \"YFM003\": \"error\" }`). A project's `.yfmlint` takes precedence over these settings."
        }
      }
    },
    "keybindings": [
      {
        "command": "diplodoc.insertTable",
        "key": "alt+t",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertNote",
        "key": "alt+r",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertCut",
        "key": "alt+c",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertTab",
        "key": "alt+a",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertCodeBlock",
        "key": "alt+o",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertInclude",
        "key": "alt+z",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertQuote",
        "key": "alt+q",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertMermaid",
        "key": "alt+m",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertFrontmatter",
        "key": "alt+f",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertPageConstructor",
        "key": "alt+p",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertHtmlBlock",
        "key": "alt+h",
        "when": "editorLangId == markdown && editorTextFocus"
      },
      {
        "command": "diplodoc.insertVideo",
        "key": "alt+v",
        "when": "editorLangId == markdown && editorTextFocus"
      }
    ],
    "commands": [
      {
        "command": "diplodoc.openMdEditor",
        "title": "Open Diplodoc Markdown Editor",
        "icon": "assets/diplodoc-logo-colored.svg",
        "enablement": "resourceLangId == markdown || diplodoc.hasBlocksYaml"
      },
      {
        "command": "diplodoc.openTocEditor",
        "title": "Open Diplodoc TOC Editor",
        "icon": "assets/diplodoc-logo-colored.svg"
      },
      {
        "command": "diplodoc.initProject",
        "title": "Diplodoc: Initialize Project"
      },
      {
        "command": "diplodoc.insertTable",
        "title": "Diplodoc: Insert Table"
      },
      {
        "command": "diplodoc.insertNote",
        "title": "Diplodoc: Insert Note"
      },
      {
        "command": "diplodoc.insertCut",
        "title": "Diplodoc: Insert Cut"
      },
      {
        "command": "diplodoc.insertTab",
        "title": "Diplodoc: Insert Tabs"
      },
      {
        "command": "diplodoc.insertCodeBlock",
        "title": "Diplodoc: Insert Code Block"
      },
      {
        "command": "diplodoc.insertInclude",
        "title": "Diplodoc: Insert Include"
      },
      {
        "command": "diplodoc.insertQuote",
        "title": "Diplodoc: Insert Quote"
      },
      {
        "command": "diplodoc.insertMermaid",
        "title": "Diplodoc: Insert Mermaid Diagram"
      },
      {
        "command": "diplodoc.insertFrontmatter",
        "title": "Diplodoc: Insert Frontmatter"
      },
      {
        "command": "diplodoc.insertPageConstructor",
        "title": "Diplodoc: Insert Page Constructor"
      },
      {
        "command": "diplodoc.insertHtmlBlock",
        "title": "Diplodoc: Insert HTML Block"
      },
      {
        "command": "diplodoc.insertVideo",
        "title": "Diplodoc: Insert Video"
      },
      {
        "command": "diplodoc.findFileReferences",
        "title": "Diplodoc: Find File in toc.yaml"
      }
    ],
    "languages": [
      {
        "id": "yaml",
        "filenames": [
          ".yfm",
          ".yfmlint",
          "toc.yaml",
          "presets.yaml",
          "redirects.yaml",
          "theme.yaml"
        ],
        "extensions": [
          ".yfm",
          ".yfmlint"
        ]
      },
      {
        "id": "markdown",
        "extensions": [
          ".md",
          ".markdown"
        ]
      }
    ],
    "grammars": [
      {
        "path": "./syntaxes/markdown-page-constructor.json",
        "scopeName": "markdown.pc.codeblock",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.yaml": "yaml"
        }
      },
      {
        "path": "./syntaxes/markdown-liquid.json",
        "scopeName": "markdown.liquid.inline",
        "injectTo": [
          "text.html.markdown"
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "diplodoc.openMdEditor",
          "when": "resourceLangId == markdown || diplodoc.hasBlocksYaml",
          "group": "navigation@1"
        },
        {
          "command": "diplodoc.openTocEditor",
          "when": "resourceFilename =~ /^toc(-.+)?\\.yaml$/",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "diplodoc.findFileReferences",
          "when": "resourceLangId == markdown || resourceLangId == yaml",
          "group": "4_search"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "diplodoc-extension",
          "title": "Diplodoc",
          "icon": "./assets/diplodoc-logo-colored.svg"
        }
      ]
    },
    "views": {
      "diplodoc-extension": [
        {
          "type": "webview",
          "id": "diplodoc-extension-view",
          "name": "Diplodoc",
          "icon": "./assets/diplodoc-logo-colored.svg"
        }
      ]
    }
  },
  "scripts": {
    "compile:ext": "BUILD_TARGET=ext node esbuild.js",
    "compile:webview": "BUILD_TARGET=webview node esbuild.js",
    "compile": "node esbuild.js",
    "build": "node esbuild.js",
    "watch:ext": "BUILD_TARGET=ext node esbuild.js --watch",
    "watch:webview": "BUILD_TARGET=webview node esbuild.js --watch",
    "typecheck": "tsc -p . --noEmit",
    "vsce": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "lint",
    "lint:fix": "lint fix",
    "lint:update": "lint update",
    "remove-vsix": "rm -f *.vsix",
    "pre-commit": "lint-staged",
    "prepare": "husky || true",
    "lock": "npm install --no-workspaces --package-lock-only --ignore-scripts"
  },
  "dependencies": {
    "@diplodoc/ajv": "^0.0.6",
    "@diplodoc/html-extension": "^2.9.9",
    "@diplodoc/latex-extension": "^1.4.1",
    "@diplodoc/mermaid-extension": "^2.1.1",
    "@diplodoc/transform": "^4.75.4",
    "@diplodoc/utils": "^2.3.1",
    "@diplodoc/yfmlint": "^1.7.6",
    "@gravity-ui/components": "^4.18.0",
    "@gravity-ui/icons": "^2.18.0",
    "@gravity-ui/markdown-editor": "^15.39.0",
    "@gravity-ui/markdown-editor-page-constructor-extension": "^0.1.0",
    "@gravity-ui/uikit": "^7.37.0",
    "@vscode/extension-telemetry": "^1.5.2",
    "colord": "^2.9.3",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "lowlight": "^3.3.0",
    "markdown-it": "^13.0.2",
    "punycode": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "url": "^0.11.4",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5",
    "yaml-language-server": "^1.21.0"
  },
  "devDependencies": {
    "@diplodoc/infra": "2.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "esbuild-sass-plugin": "^3.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-fetch": "^3.3.2",
    "sass": "^1.98.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
